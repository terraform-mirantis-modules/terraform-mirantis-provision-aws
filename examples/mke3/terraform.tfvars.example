// used to name infrastructure (CHANGE THIS)
name = "mirantis"
aws = {
  region = "us-east-1"
}

// Set the username/password accordingly
mke = {
  drain = false

  mcr_version = "23.0.12"
  mke_version = "3.7.9"
  msr_version = ""

  mke_connect = {
    username = ""
    password = ""
    insecure = false
  }
}

subnets = {
  "AMain" = {
    cidr       = "172.31.0.0/17"
    nodegroups = ["AMngr"]
    private    = false
  }
  "AWorkers" = {
    cidr       = "172.31.128.0/17"
    nodegroups = ["AWrk"]
    private    = false
  }
}

// configure the network stack
network = {
  # private_subnet_count = 0 // if 0 then no private nodegroups allowed
  enable_vpn_gateway = false
  enable_nat_gateway = false
  cidr               = "172.31.0.0/16"
}

// one definition for each group of machines to include in the stack
nodegroups = {
  "AMngr" = { // managers for A group
    ami_id      = "ami-xxxxxxxxxxxxxxxxx" // your AMI ID
    ami_owner   = "123456789012"          // your AWS account ID
    ssh_user    = "cloud-user"
    count       = 1
    type        = "m6a.2xlarge"
    volume_size = 100
    role        = "manager"
    public      = true
    user_data   = ""
  },
  "AWrk" = { // workers for A group
    ami_id      = "ami-xxxxxxxxxxxxxxxxx" // your AMI ID
    ami_owner   = "123456789012"          // your AWS account ID
    ssh_user    = "cloud-user"
    count       = 1
    type        = "c6a.xlarge"
    volume_size = 100
    public      = true
    role        = "worker"
    user_data   = ""
  }
}

// set a windows password, if you have windows nodes
# windows_password = ""